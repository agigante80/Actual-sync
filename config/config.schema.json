{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Actual-sync Configuration",
  "description": "Configuration schema for Actual-sync service",
  "type": "object",
  "required": ["servers"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema reference for editor autocomplete/validation. Ignored at runtime."
    },
    "servers": {
      "type": "array",
      "description": "Array of Actual Budget server configurations",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "url", "password", "syncId", "dataDir"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Human-readable name for the server",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "description": "Actual Budget server URL",
            "pattern": "^https?://.+",
            "examples": ["http://localhost:5006", "https://actual.example.com"]
          },
          "password": {
            "type": "string",
            "description": "Server password",
            "minLength": 1
          },
          "syncId": {
            "type": "string",
            "description": "Budget sync ID from Actual Budget settings",
            "minLength": 1
          },
          "dataDir": {
            "type": "string",
            "description": "Local directory for budget file cache",
            "minLength": 1
          },
          "encryptionPassword": {
            "type": "string",
            "description": "Budget file encryption password (optional, only needed if budget is encrypted with end-to-end encryption)",
            "minLength": 1
          },
          "sync": {
            "type": "object",
            "description": "Server-specific sync configuration (overrides global settings)",
            "properties": {
              "maxRetries": {
                "type": "integer",
                "description": "Maximum number of retry attempts for this server",
                "minimum": 0,
                "maximum": 10
              },
              "baseRetryDelayMs": {
                "type": "integer",
                "description": "Base delay in milliseconds for exponential backoff for this server",
                "minimum": 1000,
                "maximum": 10000
              },
              "schedule": {
                "type": "string",
                "description": "Cron expression for sync schedule for this server",
                "pattern": "^[0-9A-Za-z*,/?#-]+\\s+[0-9A-Za-z*,/?#-]+\\s+[0-9A-Za-z*,/?#-]+\\s+[0-9A-Za-z*,/?#-]+\\s+[0-9A-Za-z*,/?#-]+$",
                "examples": ["0 2 * * *", "*/30 * * * *", "0 2 * * MON"]
              },
              "autoRetry": {
                "type": "object",
                "description": "Automatic retry for failed automated syncs for this server (overrides global; does NOT apply to manual syncs)",
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "description": "Enable automatic retry for failed automated syncs"
                  },
                  "maxAttempts": {
                    "type": "integer",
                    "description": "Maximum number of retry attempts after initial failure",
                    "minimum": 0,
                    "maximum": 5
                  },
                  "delayMinutes": {
                    "type": "integer",
                    "description": "Delay in minutes between retry attempts",
                    "minimum": 1,
                    "maximum": 1440
                  }
                }
              }
            }
          },
          "logging": {
            "type": "object",
            "description": "Server-specific logging configuration (overrides global settings)",
            "properties": {
              "level": {
                "type": "string",
                "description": "Log level for this server (DEBUG, INFO, WARN, ERROR)",
                "enum": ["DEBUG", "INFO", "WARN", "ERROR", "debug", "info", "warn", "error"]
              },
              "format": {
                "type": "string",
                "description": "Log output format for this server",
                "enum": ["pretty", "json"]
              }
            }
          }
        }
      }
    },
    "sync": {
      "type": "object",
      "description": "Global sync behavior configuration (can be overridden per server)",
      "properties": {
        "maxRetries": {
          "type": "integer",
          "description": "Maximum number of retry attempts",
          "minimum": 0,
          "maximum": 10,
          "default": 5
        },
        "baseRetryDelayMs": {
          "type": "integer",
          "description": "Base delay in milliseconds for exponential backoff",
          "minimum": 1000,
          "maximum": 10000,
          "default": 3000
        },
        "schedule": {
          "type": "string",
          "description": "Cron expression for sync schedule",
          "pattern": "^[0-9A-Za-z*,/?#-]+\\s+[0-9A-Za-z*,/?#-]+\\s+[0-9A-Za-z*,/?#-]+\\s+[0-9A-Za-z*,/?#-]+\\s+[0-9A-Za-z*,/?#-]+$",
          "default": "03 03 */2 * *",
          "examples": ["0 2 * * *", "*/30 * * * *", "0 2 * * MON"]
        },
        "autoRetry": {
          "type": "object",
          "description": "Automatic retry configuration for failed automated syncs (does NOT apply to manual syncs)",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable automatic retry for failed automated syncs",
              "default": true
            },
            "maxAttempts": {
              "type": "integer",
              "description": "Maximum number of retry attempts after initial failure",
              "minimum": 0,
              "maximum": 5,
              "default": 1
            },
            "delayMinutes": {
              "type": "integer",
              "description": "Delay in minutes between retry attempts",
              "minimum": 1,
              "maximum": 1440,
              "default": 31
            }
          }
        }
      }
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "level": {
          "type": "string",
          "description": "Global log level (DEBUG, INFO, WARN, ERROR)",
          "enum": ["DEBUG", "INFO", "WARN", "ERROR", "debug", "info", "warn", "error"],
          "default": "INFO"
        },
        "format": {
          "type": "string",
          "description": "Console log output format",
          "enum": ["pretty", "json"],
          "default": "pretty"
        },
        "fileFormat": {
          "type": "string",
          "description": "Log file output format. JSON (single line per entry) is recommended for production so logs are machine-parseable and shippable. Independent of the console 'format'. Global only: log files are a single shared stream, so this is not a per-server setting.",
          "enum": ["pretty", "json"],
          "default": "json"
        },
        "redact": {
          "type": "array",
          "description": "Additional metadata key names to mask as [REDACTED] in all log output, on top of the always-on defaults. The defaults are matched as case-insensitive substrings: password, passwd, token, secret, apikey, api_key, authorization, credential, chatid (so encryptionPassword, botToken, etc. are covered).",
          "items": { "type": "string", "minLength": 1 }
        },
        "logDir": {
          "type": ["string", "null"],
          "description": "Directory for log files (set to null to disable file logging). For Docker deployments, use /app/logs. Defaults to './logs' if not specified.",
          "default": "./logs"
        },
        "rotation": {
          "type": "object",
          "description": "Log rotation settings (enabled by default with 30-day retention)",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable log rotation (recommended for production)",
              "default": true
            },
            "maxSize": {
              "type": "string",
              "description": "Maximum size per log file before rotation, as a number plus a unit B/K/M/G (e.g., '10M', '50M', '100M'). Rotation fires on whichever trigger comes first: this size or the interval.",
              "pattern": "^[0-9]+[BKMG]$",
              "default": "10M"
            },
            "interval": {
              "type": "string",
              "description": "Time-based rotation interval, as a number plus a unit: s/m/h/d or M for months (e.g., '1d', '12h', '1M'). Note m = minutes, M = months. Ensures logs rotate even at low volume, so maxFiles behaves as documented (days of retention).",
              "pattern": "^[0-9]+[smhdM]$",
              "default": "1d"
            },
            "maxFiles": {
              "type": "integer",
              "description": "Maximum number of rotated log files to keep. With the default '1d' interval this is days of retention.",
              "minimum": 1,
              "maximum": 1000,
              "default": 30
            },
            "compress": {
              "type": "string",
              "description": "Compression format for archived logs (gzip saves ~70% disk space)",
              "enum": ["gzip", "none"],
              "default": "gzip"
            }
          }
        },
        "syslog": {
          "type": "object",
          "description": "Syslog centralized logging configuration",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable syslog output",
              "default": false
            },
            "host": {
              "type": "string",
              "description": "Syslog server hostname",
              "minLength": 1,
              "default": "localhost"
            },
            "port": {
              "type": "integer",
              "description": "Syslog server port",
              "minimum": 1,
              "maximum": 65535,
              "default": 514
            },
            "protocol": {
              "type": "string",
              "description": "Protocol to use (udp or tcp)",
              "enum": ["udp", "tcp"],
              "default": "udp"
            },
            "facility": {
              "type": "integer",
              "description": "Syslog facility code (0-23)",
              "minimum": 0,
              "maximum": 23,
              "default": 16
            }
          }
        },
        "performance": {
          "type": "object",
          "description": "Performance logging settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable performance metrics logging",
              "default": false
            },
            "thresholds": {
              "type": "object",
              "description": "Performance thresholds in milliseconds",
              "properties": {
                "slow": {
                  "type": "integer",
                  "description": "Threshold for slow operations (ms)",
                  "minimum": 100,
                  "maximum": 3600000,
                  "default": 1000
                },
                "verySlow": {
                  "type": "integer",
                  "description": "Threshold for very slow operations (ms)",
                  "minimum": 100,
                  "maximum": 3600000,
                  "default": 5000
                }
              }
            }
          }
        }
      }
    },
    "healthCheck": {
      "type": "object",
      "description": "Health check HTTP endpoint configuration",
      "properties": {
        "port": {
          "type": "integer",
          "description": "HTTP port for health check endpoints",
          "minimum": 1024,
          "maximum": 65535,
          "default": 3000
        },
        "host": {
          "type": "string",
          "description": "Host to bind health check server",
          "minLength": 1,
          "default": "0.0.0.0",
          "examples": ["0.0.0.0", "127.0.0.1", "localhost"]
        },
        "dashboard": {
          "type": "object",
          "description": "Dashboard authentication and access control",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable web dashboard access",
              "default": true
            },
            "auth": {
              "type": "object",
              "description": "Authentication configuration for dashboard",
              "properties": {
                "type": {
                  "type": "string",
                  "description": "Authentication type",
                  "enum": ["none", "basic", "token"],
                  "default": "none"
                },
                "username": {
                  "type": "string",
                  "description": "Username for basic authentication (required if type=basic)"
                },
                "password": {
                  "type": "string",
                  "description": "Password for basic authentication (required if type=basic)"
                },
                "token": {
                  "type": "string",
                  "description": "Bearer token for token authentication (required if type=token)"
                }
              },
              "allOf": [
                {
                  "if": { "required": ["type"], "properties": { "type": { "const": "basic" } } },
                  "then": {
                    "required": ["username", "password"],
                    "properties": {
                      "username": { "type": "string", "minLength": 1 },
                      "password": { "type": "string", "minLength": 1 }
                    }
                  }
                },
                {
                  "if": { "required": ["type"], "properties": { "type": { "const": "token" } } },
                  "then": {
                    "required": ["token"],
                    "properties": { "token": { "type": "string", "minLength": 1 } }
                  }
                }
              ]
            }
          }
        }
      }
    },
    "syncHistory": {
      "type": "object",
      "description": "Sync history persistence configuration",
      "properties": {
        "dbPath": {
          "type": "string",
          "description": "Path to SQLite database file for sync history",
          "minLength": 1,
          "default": "data/sync-history.db"
        },
        "retentionDays": {
          "type": "integer",
          "description": "Number of days to retain sync history",
          "minimum": 1,
          "maximum": 365,
          "default": 90
        }
      }
    },
    "prometheus": {
      "type": "object",
      "description": "Prometheus metrics export configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Prometheus metrics endpoint",
          "default": true
        },
        "includeDefaultMetrics": {
          "type": "boolean",
          "description": "Include Node.js default metrics (memory, CPU, etc.)",
          "default": true
        }
      }
    },
    "notifications": {
      "type": "object",
      "description": "Error notification configuration",
      "properties": {
        "email": {
          "type": "object",
          "description": "Email notification settings",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable email notifications",
              "default": false
            },
            "host": {
              "type": "string",
              "description": "SMTP server host",
              "minLength": 1,
              "default": "smtp.gmail.com",
              "examples": ["smtp.gmail.com", "smtp.sendgrid.net"]
            },
            "port": {
              "type": "integer",
              "description": "SMTP server port",
              "minimum": 1,
              "maximum": 65535,
              "default": 587
            },
            "secure": {
              "type": "boolean",
              "description": "Use TLS for SMTP connection",
              "default": false
            },
            "auth": {
              "type": "object",
              "description": "SMTP authentication credentials",
              "properties": {
                "user": {
                  "type": "string",
                  "description": "SMTP username"
                },
                "pass": {
                  "type": "string",
                  "description": "SMTP password or app-specific password"
                }
              }
            },
            "from": {
              "type": "string",
              "description": "From email address. Validated as an email only when email notifications are enabled, so a disabled stub may hold a placeholder."
            },
            "to": {
              "type": "array",
              "description": "Recipient email addresses (validated as emails only when email is enabled)",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "if": {
            "required": ["enabled"],
            "properties": { "enabled": { "const": true } }
          },
          "then": {
            "properties": {
              "from": { "type": "string", "format": "email" },
              "to": { "type": "array", "items": { "type": "string", "format": "email" } }
            }
          }
        },
        "telegram": {
          "type": "object",
          "additionalProperties": false,
          "description": "Telegram bot settings for notifications and commands",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Telegram bot",
              "default": false
            },
            "botToken": {
              "type": "string",
              "description": "Telegram bot token from @BotFather. The 'digits:token' format is enforced only when telegram is enabled, so a disabled stub may hold a placeholder."
            },
            "chatId": {
              "type": "string",
              "description": "Chat ID (user ID, group ID, or channel username)"
            },
            "chatIds": {
              "type": "array",
              "description": "One or more chat IDs (alternative to chatId). The first entry is used for outbound notifications; the bot also accepts numeric IDs.",
              "items": { "type": ["string", "number"], "minLength": 1 }
            },
            "notifyOnSuccess": {
              "type": "string",
              "description": "When to send sync notifications",
              "enum": ["always", "errors_only", "never"],
              "default": "errors_only"
            },
            "pollInterval": {
              "type": "integer",
              "description": "Polling interval in milliseconds for the interactive bot",
              "minimum": 100,
              "maximum": 3600000,
              "default": 2000
            }
          },
          "if": {
            "required": ["enabled"],
            "properties": { "enabled": { "const": true } }
          },
          "then": {
            "required": ["botToken"],
            "properties": {
              "botToken": { "type": "string", "pattern": "^[0-9]+:[A-Za-z0-9_-]+$" }
            },
            "anyOf": [
              { "required": ["chatId"], "properties": { "chatId": { "type": "string", "minLength": 1 } } },
              { "required": ["chatIds"], "properties": { "chatIds": { "type": "array", "minItems": 1 } } }
            ]
          }
        },
        "branding": {
          "type": "boolean",
          "description": "Stamp the Actual-sync project name and icon onto Slack/Discord/ntfy notifications. Set false to keep a webhook's own configured app identity, or to stop ntfy from fetching the project icon from GitHub on an air-gapped network.",
          "default": true
        },
        "webhooks": {
          "type": "object",
          "description": "Webhook notification settings",
          "properties": {
            "telegram": {
              "type": "array",
              "description": "Legacy per-webhook Telegram bot configs (an alternative to the top-level notifications.telegram). Each entry posts to one bot + chat.",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string", "description": "Webhook name for identification" },
                  "botToken": { "type": "string", "description": "Telegram bot token from @BotFather", "minLength": 1 },
                  "chatId": { "type": "string", "description": "Target chat ID", "minLength": 1 }
                },
                "required": ["botToken", "chatId"]
              }
            },
            "slack": {
              "type": "array",
              "description": "Slack webhook configurations",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Webhook name for identification"
                  },
                  "url": {
                    "type": "string",
                    "description": "Slack webhook URL",
                    "pattern": "^https://hooks\\.slack\\.com/.*"
                  }
                },
                "required": ["url"]
              }
            },
            "discord": {
              "type": "array",
              "description": "Discord webhook configurations",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Webhook name for identification"
                  },
                  "url": {
                    "type": "string",
                    "description": "Discord webhook URL",
                    "pattern": "^https://discord\\.com/api/webhooks/.*"
                  }
                },
                "required": ["url"]
              }
            },
            "generic": {
              "type": "array",
              "description": "Generic webhook configurations. Each receives a documented JSON payload (status, server, account counts and lists) via HTTP POST. Works with ntfy (JSON publishing), Gotify, Home Assistant, n8n, and custom endpoints.",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Webhook name for identification"
                  },
                  "url": {
                    "type": "string",
                    "description": "Destination URL the JSON payload is POSTed to",
                    "minLength": 1,
                    "pattern": "^https?://.+"
                  },
                  "enabled": {
                    "type": "boolean",
                    "description": "Set false to disable this webhook without removing it",
                    "default": true
                  },
                  "headers": {
                    "type": "object",
                    "description": "Extra HTTP headers to send (e.g. Authorization, Priority). Secrets are redacted in logs.",
                    "additionalProperties": { "type": "string" }
                  },
                  "contentType": {
                    "type": "string",
                    "description": "Override the request Content-Type",
                    "default": "application/json"
                  }
                },
                "required": ["url"]
              }
            }
          }
        },
        "ntfy": {
          "type": "object",
          "description": "ntfy push notifications (https://ntfy.sh). Posts to a topic URL with Title/Priority/Tags headers.",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable ntfy notifications",
              "default": false
            },
            "url": {
              "type": "string",
              "description": "Full topic URL, e.g. https://ntfy.sh/my-topic or https://ntfy.example.com/my-topic"
            },
            "token": {
              "type": "string",
              "description": "Optional access token sent as 'Authorization: Bearer <token>'. Redacted in logs."
            },
            "priorityOnFailure": {
              "type": "string",
              "description": "ntfy priority for failure notifications",
              "enum": ["max", "urgent", "high", "default", "low", "min"],
              "default": "high"
            },
            "priorityOnSuccess": {
              "type": "string",
              "description": "ntfy priority for success/info notifications",
              "enum": ["max", "urgent", "high", "default", "low", "min"],
              "default": "default"
            },
            "tags": {
              "type": "array",
              "description": "Base ntfy tags/emoji added to every notification",
              "items": { "type": "string", "minLength": 1 }
            },
            "icon": {
              "type": "string",
              "anyOf": [
                { "const": "" },
                { "format": "uri" }
              ],
              "description": "URL of an icon shown in the ntfy notification (sent as the Icon header). Defaults to the Actual-sync project icon; set to an empty string to send no icon."
            }
          },
          "if": { "required": ["enabled"], "properties": { "enabled": { "const": true } } },
          "then": { "required": ["url"], "properties": { "url": { "type": "string", "minLength": 1 } } }
        },
        "thresholds": {
          "type": "object",
          "description": "Notification threshold settings",
          "properties": {
            "consecutiveFailures": {
              "type": "integer",
              "description": "Number of consecutive failures before notification",
              "minimum": 1,
              "maximum": 20,
              "default": 3
            },
            "failureRate": {
              "type": "number",
              "description": "Failure rate (0-1) threshold over rate period",
              "minimum": 0,
              "maximum": 1,
              "default": 0.5
            },
            "ratePeriodMinutes": {
              "type": "integer",
              "description": "Time period in minutes for failure rate calculation",
              "minimum": 5,
              "maximum": 1440,
              "default": 60
            }
          }
        },
        "rateLimit": {
          "type": "object",
          "description": "Notification rate limiting settings",
          "properties": {
            "minIntervalMinutes": {
              "type": "integer",
              "description": "Minimum minutes between notifications",
              "minimum": 1,
              "maximum": 1440,
              "default": 15
            },
            "maxPerHour": {
              "type": "integer",
              "description": "Maximum notifications per hour",
              "minimum": 1,
              "maximum": 20,
              "default": 4
            }
          }
        }
      }
    }
  }
}
