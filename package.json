{
  "name": "actual-sync",
  "version": "1.8.4",
  "description": "Automated bank synchronization service for Actual Budget",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "sync": "node index.js --force-run",
    "list-accounts": "node scripts/listAccounts.js",
    "history": "node scripts/viewHistory.js",
    "validate-config": "node scripts/validateConfig.js",
    "screenshots": "node scripts/generateDashboardScreenshots.js",
    "version:bump": "node scripts/version-bump.js",
    "release:patch": "node scripts/version-bump.js patch",
    "release:minor": "node scripts/version-bump.js minor",
    "release:major": "node scripts/version-bump.js major",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js",
      "!src/syncService.js",
      "!src/__tests__/**",
      "!index.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/?(*.)+(spec|test).js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/",
      "/coverage/"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 61,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "keywords": [
    "actual-budget",
    "banking",
    "sync",
    "automation",
    "finance"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@actual-app/api": "^26.6.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.10.0",
    "cronstrue": "^3.14.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "moment-timezone": "^0.6.2",
    "node-schedule": "^2.1.1",
    "nodemailer": "^8.0.11",
    "prom-client": "^15.1.3",
    "rotating-file-stream": "^3.2.9",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "puppeteer": "^24.41.0"
  }
}
